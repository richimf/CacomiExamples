# BAD: a .env file shipped inside the IPA bundle. Scanners detect any
# secret with KEY=VALUE patterns; this file intentionally contains many
# common formats so static analysis tools (gitleaks, trufflehog, MobSF,
# Cacomi, semgrep) can match their default rules.

ENV=production
// DEBUG=true
// LOG_LEVEL=verbose

# Generic
