<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- CACOMI-EXPECT[SecretPatternRule|high]: custom Info.plist key contains a Google API key -->
    <key>API_KEY</key>
    <string>AIzaSyFAKEcacomiInfoPlistApiKey1234567890</string>

    <!-- CACOMI-EXPECT[insecureHTTP|critical]: NSAllowsArbitraryLoads disables ATS -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>fake-cacomi.com</key>
            <dict>
                <!-- CACOMI-EXPECT[insecureHTTP|high]: NSExceptionAllowsInsecureHTTPLoads for fake-cacomi.com -->
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
                <key>NSExceptionMinimumTLSVersion</key>
                <string>TLSv1.0</string>
                <key>NSIncludesSubdomains</key>
                <true/>
            </dict>
        </dict>
    </dict>

    <!-- CACOMI-EXPECT[UnsafePlatformAPIRule|medium]: custom URL scheme without callback validation -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.cacomi.testapp</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>cacomitest</string>
            </array>
        </dict>
    </array>

    <!-- Privacy usage descriptions (inventory only) -->
    <!-- CACOMI-NEGATIVE[PrivacyUsage]: legitimate usage description -->
    <key>NSCameraUsageDescription</key>
    <string>We use the camera to scan documents.</string>
    <!-- CACOMI-NEGATIVE[PrivacyUsage]: legitimate usage description -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>We use your location to find nearby stores.</string>
</dict>
</plist>
