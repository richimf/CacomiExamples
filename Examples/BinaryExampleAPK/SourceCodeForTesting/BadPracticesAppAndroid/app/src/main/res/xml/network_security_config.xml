<?xml version="1.0" encoding="utf-8"?>
<!--
  BAD: configuracion de seguridad de red insegura // CACOMI-EXPECT: NetworkSecurityConfig / TLSTrustBypass
-->
<network-security-config>
    <!-- BAD: trafico en claro permitido globalmente -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <!-- BAD: confia en certificados instalados por el usuario (MITM) -->
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- BAD: cleartext explicito para un dominio -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">example.com</domain>
    </domain-config>

    <!-- BAD: debug-overrides con trust anchors de usuario -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
