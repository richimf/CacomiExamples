# BAD: archivo .env empaquetado dentro del APK (assets/). Equivalente de credentials.env (iOS).
# Contiene secretos dummy en multiples formatos para que los scanners (gitleaks,
# trufflehog, MobSF, Cacomi, semgrep) los detecten. TODOS los valores son FAKE.
# CACOMI-EXPECT: SecretPattern/HighEntropy

ENV=production
# NEGATIVO: feature flag, no es un secreto // CACOMI-EXPECT: none
FEATURE_NEW_UI=true

# Generic
API_KEY=cacomi_env_api_key_FAKE_1234567890abcdef
SECRET_KEY=cacomi_env_secret_key_FAKE_0987654321zyxwvu
CLIENT_ID=fake-cacomi-env-client-id-12345
CLIENT_SECRET=fake-cacomi-env-client-secret-abcdefghijklmnopqrstuvwxyz

# AWS
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_SESSION_TOKEN=FwoGZXIvYXdzEPb-CacomiFakeSessionTokenForScannerDetection==

# Google / Firebase
GOOGLE_API_KEY=AIzaSyDuFAKEcacomiEnvGoogleAPIkey1234567890
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-FAKEcacomiEnvGoogleOAuthSecret1234567
FIREBASE_DB_URL=https://fake-cacomi-default-rtdb.firebaseio.com

# GitHub / GitLab
GITHUB_TOKEN=ghp_FAKEcacomiENVgithubToken1234567890abcdefghij
GITLAB_TOKEN=glpat-FAKEcacomi-env-gitlab-PAT-1234567890ab

# Stripe / Square
STRIPE_SECRET_KEY=sk_live_FAKEcacomiENVstripeLIVE51HxYzAbCdEfGhIjKlMnOpQrStUvWxYz
SQUARE_ACCESS_TOKEN=sq0atp-FAKEcacomiENVsquareAccessToken1234

# DB
