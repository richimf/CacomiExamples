<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidManifest del banco de pruebas BadPracticesAppAndroid.
  Todas las malas practicas son INTENCIONALES para que Cacomi las detecte en el
  binario (AXML). Familias: AndroidManifest / AndroidComponentMisuse /
  PrivacyPermission / NetworkSecurityConfig.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- BAD: permisos peligrosos declarados sin uso real // CACOMI-EXPECT: PrivacyPermission/PII -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- BAD: QUERY_ALL_PACKAGES (privacidad) // CACOMI-EXPECT: PrivacyPermission -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <!-- Soporte (usados por la demo de red/almacenamiento) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- BAD (Phase E): combinacion de permisos peligrosos tipica de un RAT / payload
         (SMS + microfono + camara + contactos + registro de llamadas + telefono +
         ubicacion + estado del telefono). Junto con el componente de firma de abajo,
         el APK queda como payload de acceso remoto. NOTA: cuando hay coincidencia de
         FIRMA (com.metasploit.stage.*), AndroidPayloadSignatureRule reporta el hallazgo
         critico y NO emite ademas el heuristico de combo; si se quita el componente de
         firma, este combo (>=9) dispararia "Over-privileged RAT (high)".
         // CACOMI-EXPECT: PrivacyPermission (cada permiso) + arma el heuristico RAT -->
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.SET_WALLPAPER" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BadPracticesAppAndroid"
        android:networkSecurityConfig="@xml/network_security_config"
        android:debuggable="true"
        android:testOnly="true"
        android:usesCleartextTraffic="true"
        tools:ignore="HardcodedDebugMode,AllowBackup,TestOnlyProblem,Instantiatable">

        <!-- BAD: secreto dummy en meta-data del manifest // CACOMI-EXPECT: SecretPattern -->
        <meta-data
            android:name="com.example.API_KEY"
            android:value="AIzaSyA-EXAMPLE-DO-NOT-USE-1234567890abcdEX" />
        <!-- BAD: endpoint/clave de proveedor de IA (inventory) // CACOMI-EXPECT: AIDiscovery -->
        <meta-data
            android:name="com.example.OPENAI_API_KEY"
            android:value="sk-proj-EXAMPLE000000000000000000000000000000000000EX" />

        <!-- NEGATIVO: Activity declarada en manifest -> NO debe marcarse como codigo no usado // CACOMI-EXPECT: none -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.BadPracticesAppAndroid"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- BAD: Activity con handler onClick desde XML (negativo de UnusedCode para el handler) -->
        <!-- BAD: filterTouchesWhenObscured implicitamente false (tapjacking) // CACOMI-EXPECT: AndroidComponentMisuse -->
        <activity
            android:name=".components.LegacyActivity"
            android:exported="true"
            tools:ignore="ExportedActivity" />

        <!-- BAD: App Link http/https SIN android:autoVerify="true" // CACOMI-EXPECT: AndroidManifest/AppLink -->
        <activity
            android:name=".components.DeepLinkActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="example.com" />
                <data android:scheme="http" android:host="example.com" />
            </intent-filter>
        </activity>

        <!-- BAD: Service exported sin permiso // CACOMI-EXPECT: AndroidComponentMisuse -->
        <service
            android:name=".components.ExportedService"
            android:exported="true" />

        <!-- BAD: Receiver exported sin permiso + intent-filter // CACOMI-EXPECT: AndroidComponentMisuse -->
        <receiver
            android:name=".components.ExportedReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- BAD: Provider exported sin permiso // CACOMI-EXPECT: AndroidComponentMisuse -->
        <provider
            android:name=".components.ExportedProvider"
            android:authorities="com.example.badpracticesappandroid.provider"
            android:exported="true"
            tools:ignore="ExportedContentProvider" />

        <!-- NEGATIVO: Service interno NO exportado // CACOMI-EXPECT: none -->
        <service
            android:name=".components.SafeInternalService"
            android:exported="false" />

        <!-- BAD: Activity exportada sin permiso con intent-filter de accion personalizada.
             Cualquier app puede invocarla y enviarle datos arbitrarios (M4/M6).
             CACOMI-EXPECT: ExportedComponent -->
        <activity
            android:name=".components.ExportedDeepLinkReceiverActivity"
            android:exported="true"
            tools:ignore="ExportedActivity">
            <intent-filter>
                <action android:name="com.example.badpracticesappandroid.action.OPEN_SCREEN" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- BAD: Service exportado con intent-filter sin android:permission (M6).
             Un proceso externo puede bindear o iniciar este servicio libremente.
             CACOMI-EXPECT: ExportedComponent -->
        <service
            android:name=".components.ExportedServiceWithFilter"
            android:exported="true"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="com.example.badpracticesappandroid.action.SYNC" />
            </intent-filter>
        </service>

        <!-- BAD (Phase E): componente cuyo nombre coincide con la firma del payload
             Android de Metasploit / msfvenom (paquete `com.metasploit.stage.*`). El walk
             del manifest marca el APK como payload de acceso remoto conocido (RAT).
             Clase stub inerte en app/src/main/java/com/metasploit/stage/MainService.kt.
             // CACOMI-EXPECT: Known Metasploit / msfvenom Android payload (malwarePayload, critical, CWE-506) -->
        <service
            android:name="com.metasploit.stage.MainService"
            android:exported="true"
            tools:ignore="ExportedService" />

    </application>

</manifest>
