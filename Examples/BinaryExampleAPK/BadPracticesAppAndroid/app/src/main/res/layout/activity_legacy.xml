<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout XML de LegacyActivity.
  NEGATIVO de UnusedCode: el metodo handleLegacyClick() del Activity se invoca SOLO
  desde android:onClick aqui; Cacomi NO debe marcarlo como no usado. // CACOMI-EXPECT: none
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:filterTouchesWhenObscured="false">

    <Button
        android:id="@+id/legacy_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Click"
        android:onClick="handleLegacyClick" />
</LinearLayout>
